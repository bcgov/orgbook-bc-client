{
  "name": "orgbook-bc-client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run build:docs && vite && npm run watch:docs",
    "build": "npm run build:docs && vite build",
    "serve": "vite preview",
    "build:docs": "node build/docs.js",
    "watch:docs": "node build/watch.js",
    "test:unit": "vite test:unit",
    "test:e2e": "vite test:e2e",
    "lint": "eslint --ext .js,.vue --ignore-path .gitignore",
    "lint:fix": "npm run lint --fix",
    "i18n:report": "vite i18n:report --src \"./src/**/*.?(js|vue)\" --locales \"./src/i18n/**/*.json\""
  },
  "dependencies": {
    "@snowplow/browser-tracker": "^3.1.6",
    "@vue/compat": "^3.4.25",
    "axios": "^0.21.4",
    "lodash-es": "^4.17.21",
    "moment": "^2.29.1",
    "register-service-worker": "^1.7.1",
    "vue": "^3.4.25",
    "vue-class-component": "^7.2.3",
    "vue-i18n": "^9.0.0",
    "vue-property-decorator": "^9.1.2",
    "vue-router": "^4.3.2",
    "vuetify": "^3.0.0",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@intlify/vue-i18n-loader": "^1.0.0",
    "@mdi/js": "^5.9.55",
    "@types/jest": "^24.0.19",
    "@types/lodash-es": "^4.17.4",
    "@typescript-eslint/eslint-plugin": "^5.6.0",
    "@typescript-eslint/parser": "^5.6.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/compiler-sfc": "^3.4.25",
    "@vue/eslint-config-prettier": "^6.0.0",
    "@vue/eslint-config-typescript": "^7.0.0",
    "@vue/test-utils": "^1.2.2",
    "chokidar": "^3.5.2",
    "eslint": "^8.57.0",
    "eslint-plugin-cypress": "^2.12.1",
    "eslint-plugin-prettier": "^3.4.1",
    "eslint-plugin-vue": "^8.7.1",
    "eslint-plugin-vuetify": "^2.4.0",
    "front-matter": "^4.0.2",
    "glob": "^7.1.7",
    "marked": "^3.0.1",
    "prettier": "^2.2.1",
    "sass": "^1.75.0",
    "typescript": "~4.1.5",
    "vite": "^5.2.10"
  }
}
